---
import Base from '../layouts/Base.astro';
import ProjectList from '../components/ProjectList.astro';
import Gallery from '../components/Gallery.astro';
import Experience from '../components/Experience.astro';
---
<Base title="Adam Crespi">
  <main>
    <div class="hero">
      <div>
        <h1>Adam Crespi</h1>
        <p class="meta">Engineering Physics · Vancouver / San Francisco · <a href="mailto:adamcrespi43@gmail.com">adamcrespi43@gmail.com</a></p>
      </div>
      <img src="/images/milahead.png" alt="Mila the cat" class="cat" />
    </div>

    <p class="bio">I'm interested in the embedded software underneath autonomous vehicles and robotics — real-time scheduling, kernel internals, functional safety, the layer where a bug is a deadline missed or a vehicle confused. Currently doing platform safety work at Rivian. Previously: blockchain infra, edge AI, autonomous robots.</p>

    <hr class="rule" />

    <p class="label">Projects</p>
    <ProjectList />

    <hr class="rule" />

    <p class="label">Experience</p>
    <Experience />

    <hr class="rule" />

    <p class="label">In the lab</p>
    <Gallery />

    <hr class="rule" />

    <footer class="meta">
      <a href="mailto:adamcrespi43@gmail.com">email</a> &nbsp;·&nbsp;
      <a href="https://www.linkedin.com/in/adam-crespi/">linkedin</a>
    </footer>
  </main>
</Base>

<style>
  .bio {
    font-size: 17px; line-height: 1.7; color: var(--soft);
    margin: 22px 0 0;
  }
  .hero {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
  }
  .cat {
    width: 116px;
    height: 116px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
  }
</style>
